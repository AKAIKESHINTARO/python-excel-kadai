      "source": [
        "import pandas as pd\n",
        "\n",
        "# データ作成\n",
        "df = pd.DataFrame({\n",
        "    '日付': [\n",
        "        '2023-05-17',\n",
        "        '2023-05-18',\n",
        "        '2023-05-19',\n",
        "        '2023-05-20',\n",
        "        '2023-05-21'\n",
        "    ],\n",
        "    '社員名': [\n",
        "        '山田',\n",
        "        '佐藤',\n",
        "        '鈴木',\n",
        "        '田中',\n",
        "        '高橋'\n",
        "    ],\n",
        "    '売上': [\n",
        "        100,\n",
        "        200,\n",
        "        150,\n",
        "        300,\n",
        "        250\n",
        "    ],\n",
        "    '部門': [\n",
        "        'メーカー',\n",
        "        '代理店',\n",
        "        'メーカー',\n",
        "        '商社',\n",
        "        '代理店'\n",
        "    ]\n",
        "})\n",
        "\n",
        "# 平均売上を計算\n",
        "average_sales = df['売上'].mean()\n",
        "\n",
        "# E列：平均売上\n",
        "df['平均売上'] = average_sales\n",
        "\n",
        "# F列：業績ランクを判定する関数\n",
        "def rank_judge(sales):\n",
        "    if sales >= average_sales + 50:\n",
        "        return 'A'\n",
        "    elif sales >= average_sales:\n",
        "        return 'B'\n",
        "    else:\n",
        "        return 'C'\n",
        "\n",
        "# F列：業績ランク\n",
        "df['業績ランク'] = df['売上'].apply(rank_judge)\n",
        "\n",
        "# Excelファイルに書き出し\n",
        "df.to_excel('業績.xlsx', index=False)"
      ]
    }
  ]
}
